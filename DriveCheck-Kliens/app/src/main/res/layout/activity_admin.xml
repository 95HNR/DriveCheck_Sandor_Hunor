<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    tools:context=".AdminActivity">

    <ProgressBar
        android:id="@+id/progressBarAdmin"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        tools:visibility="visible"/>

    <LinearLayout
        android:id="@+id/admin_gombok_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_torles_intervallum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Bejegyzés(ek) törlése sorszám alapján"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_teszt_adatok"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2. 100 Teszt bejegyzés hozzáadása"
            app:icon="@android:drawable/ic_input_add"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_osszes_torlese"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="3. ÖSSZES bejegyzés törlése"
            app:icon="@android:drawable/ic_menu_delete"
            app:strokeColor="@android:color/holo_red_dark"
            android:textColor="@android:color/holo_red_dark"/>

    </LinearLayout>

</LinearLayout>