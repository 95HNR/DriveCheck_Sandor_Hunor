<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        tools:context=".MainActivity">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/auto_logo"
                android:scaleType="fitCenter" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:text="Nyújts be kérelmet a főnöknek."
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_uj_bejegyzes"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:text="Kérelem benyújtása"
            app:icon="@android:drawable/ic_input_add"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_osszesites"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:text="Benyújtott kérelmek"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_elerheto_autok"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:text="Elérhető autók listázása"
            app:icon="@android:drawable/ic_menu_search"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:hint="Szerver IP címe"
            android:layout_marginBottom="20dp"
            app:startIconDrawable="@android:drawable/ic_menu_share">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_server_ip_main"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="10.0.2.16:8080"
                android:textColor="@android:color/white"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tv_server_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OFFLINE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

    </LinearLayout>
</ScrollView>