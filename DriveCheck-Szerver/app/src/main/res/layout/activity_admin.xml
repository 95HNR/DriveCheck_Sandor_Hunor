<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212"> <LinearLayout
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    tools:context=".uj.AdminActivity">

    <ProgressBar
        android:id="@+id/progressBarAdmin"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        tools:visibility="visible"/>

    <LinearLayout
        android:id="@+id/admin_gombok_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ERŐFORRÁS KEZELÉS"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_sofor"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Új sofőr hozzáadása"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="#381E72"
            app:backgroundTint="#D0BCFF"
            app:cornerRadius="30dp"
            android:layout_marginBottom="12dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="#381E72"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_auto"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Új autó hozzáadása"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="#381E72"
            app:backgroundTint="#D0BCFF"
            app:cornerRadius="30dp"
            android:layout_marginBottom="12dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="#381E72"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_sofor"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Sofőr\ntörlése"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#410002"
                app:backgroundTint="#FFDAD6"
                app:cornerRadius="30dp"
                android:layout_marginEnd="6dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="#410002"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_auto"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Autó\ntörlése"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#410002"
                app:backgroundTint="#FFDAD6"
                app:cornerRadius="30dp"
                android:layout_marginStart="6dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="#410002"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#49454F"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADATBÁZIS MŰVELETEK"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_torles_intervallum"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Törlés sorszám alapján"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="#381E72"
            app:backgroundTint="#D0BCFF"
            app:cornerRadius="30dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_teszt_adatok"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="100 Teszt adat generálása"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="#381E72"
            app:backgroundTint="#D0BCFF"
            app:cornerRadius="30dp"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_osszes_torlese"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="MINDEN ADAT TÖRLÉSE"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            app:backgroundTint="#B3261E"
            app:cornerRadius="30dp"/>

    </LinearLayout>
</LinearLayout>
</ScrollView>