<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        tools:context=".uj.MainActivity">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/auto_logo"
                android:scaleType="fitCenter" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:text="Adminisztrációs és\nSzerver Központ"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_kerelmek"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:text="Kérelmek kezelése"
            app:icon="@android:drawable/ic_menu_agenda"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_osszesites"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:text="Összesítés és szűrés"
            app:icon="@android:drawable/ic_menu_search"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_admin"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:text="Adminisztrációs műveletek"
            app:icon="@android:drawable/ic_menu_manage"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_server_toggle"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:text="OFFLINE"
            android:backgroundTint="#C62828"
            android:textColor="@android:color/white"
            app:iconTint="@android:color/white"
            app:icon="@android:drawable/ic_lock_power_off"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tv_server_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Szerver: Kikapcsolva"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#BDBDBD"
            android:layout_marginBottom="10dp"/>

    </LinearLayout>
</ScrollView>